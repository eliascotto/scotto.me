---
import BaseLayout from "./BaseLayout.astro";
import Menu from "../components/Menu.astro";
import Footer from "../components/Footer.astro";
import type { LayoutProps } from "../types/layout";

type Props = LayoutProps;

const { currentPath, ...rest } = Astro.props as Props;
const pathname = currentPath ?? Astro.url.pathname;
---

<BaseLayout currentPath={pathname} {...rest}>
    <Menu currentPath={pathname} />
    <main role="main" class="max-w-2xl flex flex-col min-w-0 flex-1">
        <slot />
        <Footer />
    </main>
</BaseLayout>
