---
import HeadMetadata from "../components/HeadMetadata.astro";
import StatsCounter from "../components/StatsCounter.astro";
import StructuredData from "../components/StructuredData.astro";
import type { LayoutProps } from "../types/layout";
import "../styles/global.css";

type Props = LayoutProps;

const {
  title,
  description,
  isArticle = false,
  currentPath,
  openGraphImage,
  lang = "en-US",
  alternateLinks,
  structuredData,
} = Astro.props as Props;
const pathname = currentPath ?? Astro.url.pathname;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Metadata -->
    <HeadMetadata
      title={title}
      description={description}
      isArticle={isArticle}
      pathname={pathname}
      openGraphImage={openGraphImage}
      alternateLinks={alternateLinks}
    />

    <!-- Structured Data -->
    {structuredData && <StructuredData data={structuredData} />}

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Preload fonts -->
    <link
      rel="preload"
      href="/assets/fonts/Sora.woff"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/assets/fonts/InterVariable.woff2?v=4.1"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/assets/fonts/InterVariable-Italic.woff2?v=4.1"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
  </head>
  <body>
    <div class="p-6 pt-12 md:pt-16 flex flex-col">
      <div
        class="m-0 md:mx-auto w-full max-w-5xl flex md:flex-row flex-col justify-center gap-8"
      >
        <slot />
      </div>
    </div>
  </body><StatsCounter />
</html>
