---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" currentPath="/404/">
    <section>
        <h1 class="font-light mb-4 text-4xl">
            404 — <strong class="font-semibold">Page not found</strong>
        </h1>

        <p>
            The page you're looking for doesn't exist, or has been moved.
        </p>

        <p>
            Head back to the <a href="/">homepage</a>, or check out the <a
                href="/blog/">blog</a
            > and <a href="/archive/">archive</a>.
        </p>
    </section>
</BaseLayout>
