---
import MenuLayout from "../layouts/MenuLayout.astro";
import PostsList from "../components/PostsList.astro";
import { getAllContent } from "../lib/content";

const posts = await getAllContent();
---

<MenuLayout title="Archive" currentPath="/archive/">
  <section>
    <div class="mt-0">
      <h2 class="mt-0 title-heading text-gray-400 font-light text-base">
        Archive
      </h2>
    </div>
    <div class="flex flex-col">
      {
        posts.map((post) => (
          <PostsList post={post} note={post.collection === "notes"} />
        ))
      }
    </div>
  </section>
</MenuLayout>
